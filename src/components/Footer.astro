---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container footer-inner">
		<p class="footer-brand">Mika<span>ylin</span></p>
		<p class="footer-note">
			Soccer &middot; Photography &middot; Gaming &middot; &copy; {year} Mikaylin Naidoo
		</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--ink);
		color: #fff;
		margin-top: clamp(3rem, 6vw, 5.5rem);
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding-block: 2rem;
	}

	.footer-brand {
		font-family: var(--font-display);
		text-transform: uppercase;
		font-size: 1.2rem;
		margin: 0;
	}

	.footer-brand span {
		color: var(--accent);
	}

	.footer-note {
		margin: 0;
		font-size: 0.85rem;
		color: #b8bdca;
	}
</style>
