---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import heroPhoto from "../assets/mikaylin-hero.jpg";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const latestPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const pillars = [
	{
		href: "/football/",
		label: "Football",
		badge: "badge-football",
		copy: "Match reports, highlights, and life on the pitch.",
	},
	{
		href: "/photography/",
		label: "Photography",
		badge: "badge-photography",
		copy: "Shots from matchdays, portraits, and whatever catches my eye.",
	},
	{
		href: "/gaming/",
		label: "Gaming",
		badge: "badge-gaming",
		copy: "What I'm playing, ranking up, and current favourites.",
	},
];
---

<Layout title="Home">
	<section class="hero">
		<div class="container hero-grid">
			<div class="hero-copy">
				<span class="eyebrow">Soccer &middot; Photography &middot; Gaming</span>
				<h1>Mikaylin Naidoo</h1>
				<p class="lead">
					16-year-old baller, photographer, and full-time gamer. This is where I post
					match updates, photos, and whatever I'm currently grinding.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/blog/">Read the blog</a>
					<a class="btn btn-outline" href="/about/">About me</a>
				</div>
			</div>
			<div class="hero-photo">
				<div class="hero-photo-block"></div>
				<Image src={heroPhoto} alt="Mikaylin Naidoo" width={640} height={800} />
			</div>
		</div>
	</section>

	<section class="section pillars">
		<div class="container">
			<div class="section-head">
				<div>
					<span class="eyebrow">What I'm into</span>
					<h2>Three things, one site</h2>
				</div>
			</div>
			<div class="grid grid-3">
				{pillars.map((p) => (
					<a class="card pillar-card" href={p.href}>
						<div class="card-body">
							<span class={`badge ${p.badge}`}>{p.label}</span>
							<h3>{p.label}</h3>
							<p>{p.copy}</p>
							<span class="pillar-link">Explore &rarr;</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	{latestPosts.length > 0 && (
		<section class="section latest">
			<div class="container">
				<div class="section-head">
					<div>
						<span class="eyebrow">Fresh off the press</span>
						<h2>Latest posts</h2>
					</div>
					<a class="btn btn-outline" href="/blog/">All posts</a>
				</div>
				<div class="grid grid-3">
					{latestPosts.map((post) => <PostCard post={post} />)}
				</div>
			</div>
		</section>
	)}
</Layout>

<style>
	.hero {
		padding-block: clamp(2.5rem, 6vw, 4.5rem);
		background: var(--surface);
		border-bottom: 3px solid var(--ink);
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		align-items: center;
		gap: 2.5rem;
	}

	.hero-copy .lead {
		font-size: 1.15rem;
		max-width: 46ch;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}

	.hero-photo {
		position: relative;
		justify-self: center;
	}

	.hero-photo :global(img) {
		position: relative;
		border-radius: var(--radius);
		border: 4px solid var(--ink);
		width: 100%;
		max-width: 340px;
		height: auto;
		aspect-ratio: 4 / 5;
		object-fit: cover;
	}

	.hero-photo-block {
		position: absolute;
		inset: 18px -18px -18px 18px;
		background: var(--accent);
		border-radius: var(--radius);
	}

	@media (max-width: 860px) {
		.hero-grid {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.hero-copy .lead {
			margin-inline: auto;
		}

		.hero-actions {
			justify-content: center;
		}
	}

	.pillar-card {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.pillar-card h3 {
		margin-block: 0.75rem 0.4rem;
	}

	.pillar-link {
		display: inline-block;
		margin-top: 0.75rem;
		font-family: var(--font-display);
		text-transform: uppercase;
		font-size: 0.85rem;
		color: var(--primary);
	}
</style>
